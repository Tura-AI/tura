{
  "extends": "./app/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vite/client", "node", "bun"]
  },
  "include": [
    "app/src/**/*.ts",
    "app/src/**/*.tsx",
    "app/vite.config.ts",
    "sdk/gateway/src/**/*.ts",
    "../tui/src/agent-runtime-config.ts"
  ],
  "exclude": [
    "app/dist",
    "app/node_modules",
    "app/public",
    "app/src/**/*.test.ts",
    "app/src/**/*.test.tsx"
  ]
}
