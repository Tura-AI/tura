{
  "name": "@tura/gui-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun --cwd app dev",
    "build": "bun --cwd app build",
    "typecheck": "bun --cwd app typecheck",
    "lint": "eslint app/src sdk/gateway/src app/vite.config.ts",
    "format": "prettier --write \"app/src/**/*.{ts,tsx,css}\" \"sdk/**/*.ts\" \"tests/unit/**/*.ts\" \"tests/**/*.mjs\" \"ARCHITECTURE.md\" \"README.md\"",
    "format:check": "prettier --check \"app/src/**/*.{ts,tsx,css}\" \"sdk/**/*.ts\" \"tests/unit/**/*.ts\" \"tests/**/*.mjs\" \"ARCHITECTURE.md\" \"README.md\"",
    "unused:check": "bun --cwd app unused:check && bun --cwd sdk/gateway unused:check",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run unused:check && bun run build",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit",
    "test:e2e": "python tests/e2e/business/run_all_local.py",
    "test:business": "bun run test:e2e",
    "e2e:frontend:gui": "python tests/e2e/frontend_playwright_gui_e2e.py",
    "e2e:session-task": "python tests/e2e/session_task_workspace_e2e.py",
    "e2e:plan-session": "python tests/e2e/plan_session_backend_e2e.py",
    "e2e:settings-full": "python tests/e2e/settings_full_flow_e2e.py",
    "e2e:settings-appearance": "python tests/e2e/settings_appearance_playwright_e2e.py",
    "e2e:settings-agents": "python tests/e2e/settings_agents_playwright_e2e.py",
    "e2e:plan-panel": "python tests/e2e/plan_panel_constraints_playwright_e2e.py",
    "e2e:transcript-virtualization": "python tests/e2e/transcript_virtualization_playwright_e2e.py",
    "e2e:workbench": "python tests/e2e/workbench_smoke_e2e.py",
    "e2e:split": "bun run e2e:workbench && bun run e2e:settings-full && bun run e2e:plan-session",
    "test:live": "python tests/e2e/live/real_gateway_llm.py",
    "test:live:settings-agents-real": "python tests/e2e/live/settings_agents_real_gateway_e2e.py",
    "test:live:rounds": "python tests/e2e/live/command_run_frontend_playwright_live_rounds.py",
    "test:live:plan-pipeline": "node tests/e2e/live/plan_pipeline_real_gateway_e2e.mjs",
    "test:live:release-smoke": "python tests/e2e/live/release_web_gui_smoke.py",
    "test:live:release": "node tests/e2e/live/business/run_all_release.mjs",
    "test:live:release:single": "node tests/e2e/live/business/gui_single_request_release.mjs",
    "test:live:release:snake": "node tests/e2e/live/business/gui_snake_release.mjs",
    "test:live:release:password-zip": "node tests/e2e/live/business/gui_password_zip_release.mjs",
    "test:live:business:debug:snake": "node tests/e2e/live/business/gui_snake_debug.mjs",
    "e2e:live": "bun run test:live",
    "e2e:live:release": "bun run test:live:release",
    "e2e:live:release:single": "bun run test:live:release:single",
    "e2e:live:release:snake": "bun run test:live:release:snake",
    "e2e:live:release:password-zip": "bun run test:live:release:password-zip"
  },
  "workspaces": [
    "app",
    "sdk/gateway",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.14.2",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.48.1",
    "typescript": "^5.8.2"
  }
}
