{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tura_gui",
  "version": "0.1.0",
  "identifier": "dev.tura.tura-gui",
  "build": {
    "beforeDevCommand": "bun --cwd ../gui/app dev -- --host 127.0.0.1 --port 5174 --strictPort",
    "beforeBuildCommand": "bun --cwd ../gui build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../../gui/app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tura",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../../assets/tura/32x32.png",
      "../../../assets/tura/128x128.png",
      "../../../assets/tura/128x128@2x.png",
      "../../../assets/tura/icon.ico"
    ]
  }
}
