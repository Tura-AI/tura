{
  "name": "@tura/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "tura": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "web": "node ./scripts/web-terminal.mjs",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "test:e2e": "npm run build && node ./e2e/tui_gateway_cli_e2e.mjs",
    "test:e2e:real-snake": "node ./e2e/tui_real_gateway_snake_playwright.mjs",
    "test:stream": "npm run build && node ./e2e/business/tui_mock_gateway_stream_flow.mjs",
    "test:live": "node ./e2e/live/tui_real_gateway_session_flow.mjs",
    "test:live:greeting": "node ./tests/live/tui_greeting_stream_visibility_live.mjs",
    "test:live:snake": "node ./e2e/live/tui_web_terminal_snake_game_flow.mjs",
    "test:business": "node ./e2e/business/run_all_local.mjs",
    "test:business:single": "node ./e2e/business/tui_single_request_local.mjs",
    "test:business:snake": "node ./e2e/business/tui_snake_local.mjs",
    "test:business:password-zip": "node ./e2e/business/tui_password_zip_local.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\" \"e2e/**/*.mjs\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"e2e/**/*.mjs\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\" \"*.md\"",
    "unused:check": "knip --no-progress",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run unused:check && npm run build",
    "start": "node ./dist/index.js",
    "test:e2e:zip-password-tui": "node ./e2e/tui_zip_password_playwright.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.14.2",
    "@types/node": "^22.15.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.48.1",
    "typescript": "^5.8.3"
  }
}
