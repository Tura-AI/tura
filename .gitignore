# Local secrets and machine-specific config
.env
.env.*
!.env.example
.cargo/*
!.cargo/config.toml
.tura/

# Rust build output
target/
/bin/
/NONE

# Portable self-contained package produced by scripts/build-release.*
release/
!tests/release/
!tests/release/**

# Generated CLI launchers (scripts/install.* registers tura-tui / tura-gateway here)
cli-bin/

# JavaScript and TypeScript dependency/build output
node_modules/
**/node_modules/
**/dist/
**/.vite/
*.tsbuildinfo
/package-lock.json

# Python fallback dependencies and caches
scripts/packages/python/
commands/*/.venv/
**/__pycache__/
*.py[cod]
*$py.class

# Local databases, downloaded binaries, and storage
storage/
sessions/
db/install.ps1
db/session_log/
db/qdrant/qdrant.exe

# Logs, benchmark output, screenshots, and temporary run artifacts
log/
crates/provider/log/
artifacts/
tmp/
.tmp-*/
apps/**/test-results/
tests/command-run-codex-two-way/records/runs/
tests/command-run-codex-two-way/records/summaries/
priority-param-probe-results.json
*.bun-build
*.log
*.tmp

# Editors and OS metadata
.idea/
.vscode/
.vs/
.DS_Store
