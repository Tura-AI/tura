{
  "schema": "tura.benchmark.agent-cli-config.v1",
  "defaultAgents": ["pi", "codex", "claudecode", "opencode", "tura"],
  "agents": [
    {
      "id": "pi",
      "aliases": ["pi-agent", "pi-coding-agent"],
      "agentName": "Pi",
      "commandEnv": "COMMAND_RUN_AGENT_PI_EXE",
      "defaultCommand": "pi",
      "versionEnv": "COMMAND_RUN_AGENT_PI_VERSION",
      "modelEnv": "COMMAND_RUN_AGENT_PI_MODEL",
      "defaultModel": "openai/gpt-5.5",
      "reasoningEnv": "COMMAND_RUN_AGENT_REASONING_EFFORT",
      "defaultReasoning": "medium",
      "defaultArgs": ["--mode", "json", "--print", "--model", "{model}", "--thinking", "{reasoning}"],
      "appendInstruction": true,
      "pluginSkillGithubUrls": []
    },
    {
      "id": "codex",
      "aliases": ["codex-main", "codex-current", "current-shll", "main"],
      "agentName": "Codex CLI",
      "commandEnv": "COMMAND_RUN_AGENT_CODEX_EXE",
      "defaultCommand": "codex",
      "versionEnv": "COMMAND_RUN_AGENT_CODEX_VERSION",
      "modelEnv": "COMMAND_RUN_AGENT_CODEX_MODEL",
      "defaultModel": "gpt-5.3-codex-spark",
      "reasoningEnv": "COMMAND_RUN_AGENT_REASONING_EFFORT",
      "defaultReasoning": "medium",
      "defaultArgs": [
        "exec",
        "--json",
        "--skip-git-repo-check",
        "-C",
        "{workspace}",
        "-m",
        "{model}",
        "--dangerously-bypass-approvals-and-sandbox",
        "-c",
        "model_reasoning_effort=\"{reasoning}\""
      ],
      "appendInstruction": true,
      "pluginSkillGithubUrls": []
    },
    {
      "id": "claudecode",
      "aliases": ["claude", "claude-code", "claude-opus"],
      "agentName": "Claude Code",
      "commandEnv": "COMMAND_RUN_AGENT_CLAUDE_EXE",
      "defaultCommand": "claude",
      "versionEnv": "COMMAND_RUN_AGENT_CLAUDE_VERSION",
      "modelEnv": "COMMAND_RUN_AGENT_CLAUDE_MODEL",
      "defaultModel": "opus",
      "defaultArgs": [
        "--print",
        "--model",
        "{model}",
        "--output-format",
        "stream-json",
        "--verbose",
        "--dangerously-skip-permissions"
      ],
      "appendInstruction": true,
      "pluginSkillGithubUrls": []
    },
    {
      "id": "opencode",
      "aliases": ["open-code"],
      "agentName": "OpenCode",
      "commandEnv": "COMMAND_RUN_AGENT_OPENCODE_EXE",
      "defaultCommand": "opencode",
      "versionEnv": "COMMAND_RUN_AGENT_OPENCODE_VERSION",
      "modelEnv": "COMMAND_RUN_AGENT_OPENCODE_MODEL",
      "defaultModel": "openai/gpt-5.5",
      "defaultArgs": ["run", "--model", "{model}", "--auto"],
      "appendInstruction": true,
      "pluginSkillGithubUrls": []
    },
    {
      "id": "tura",
      "aliases": ["tura-fast", "tura-fast-shll", "tura-shll", "tura-coding-agent"],
      "agentName": "Tura",
      "commandEnv": "COMMAND_RUN_AGENT_TURA_EXE",
      "defaultCommand": "tura",
      "versionEnv": "COMMAND_RUN_AGENT_TURA_VERSION",
      "modelEnv": "COMMAND_RUN_AGENT_TURA_MODEL",
      "defaultModel": "openai/gpt-5.5",
      "reasoningEnv": "COMMAND_RUN_AGENT_REASONING_EFFORT",
      "defaultReasoning": "medium",
      "defaultArgs": [
        "exec",
        "--json",
        "--skip-git-repo-check",
        "--agent-id",
        "{turaAgentId}",
        "-m",
        "{model}",
        "--model-reasoning-effort",
        "{reasoning}",
        "--cwd",
        "{workspace}"
      ],
      "defaultEnv": {
        "OPENAI_LOGIN": "oauth",
        "TURA_COMMAND_RUN_STRICT_JSON": "0"
      },
      "defaultVariables": {
        "turaAgentId": "fast"
      },
      "appendInstruction": true,
      "pluginSkillGithubUrls": []
    }
  ]
}
