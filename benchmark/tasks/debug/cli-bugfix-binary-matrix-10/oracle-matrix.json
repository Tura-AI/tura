        {
          "path": "src/example.js",
          "content": "const value={a:1,b:2}\n"
        },
        {
          "path": "src/clean.js",
          "content": "const value = { a: 1, b: 2 };\n"
        },
        {
          "path": "README.md",
          "content": "# Title\n\nhello   world\n"
