{
  "schema": "tura.debug.cli-bugfix-binary-oracle-matrix.v1",
  "matrixPolicy": {
    "failToPass": "Cases where the configured buggy release binary must differ from the fixed release binary and the candidate must match the fixed release binary.",
    "passToPass": "Cases where buggy and fixed release binaries must already agree; the candidate must preserve that behavior.",
    "interfaceAudit": "Commands run against downloaded buggy and fixed binaries to prove the harness inspected the real CLI surface before scoring.",
    "repositoryTestsAreOracle": false
  },
