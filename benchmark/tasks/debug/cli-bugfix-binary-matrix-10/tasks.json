      },
      "bug": {
        "summary": "`prettier --list-different --cache` wrote a cache entry that caused a later `--write --cache` run to skip needed formatting.",
        "issue": "https://github.com/prettier/prettier/issues/13015",
        "issueNumber": 13015,
        "fix": "https://prettier.io/blog/2022/11/23/2.8.0.html",
        "buggyVersion": "2.7.1",
        "fixedVersion": "2.8.0",
        "buggyRef": "2.7.1",
        "fixedRef": "2.8.0",
        "agentInstruction": "Fix cache writes so read-only/listing modes cannot poison a later --write --cache invocation.",
        "issueTitle": "Unexpected --cache Behavior with --list-different",
        "issueExcerpt": "Prettier Version: 2.7.1",
        "issueText": {
          "source": "github-issue-text-snapshot",
          "title": "Unexpected --cache Behavior with --list-different",
          "body": [
            "Environment: Prettier Version 2.7.1, run through `npx`, Node v16.14.0, npm v8.3.1, no plugins.",
            "Steps: run `npx prettier . --list-different --cache`, then run `npx prettier . --write --cache`.",
            "Expected: the second command should format project code. Actual: the first command writes a cache entry, and the later write command uses that cache and does not write formatting changes."
          ]
        },
        "buggyCommit": "eeed611c728fb2f5f601440bbb78046a2a8aad83",
        "fixedCommit": "dcc0623911f8b352eda18f60683eb1a232d6c2bd"
      },
