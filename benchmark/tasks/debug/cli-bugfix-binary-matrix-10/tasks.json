        "binPath": "bin-prettier.js",
        "binaryNames": [
          "prettier"
        ]
      },
      "build": {
        "commands": [
          [
            "yarn",
            "install",
            "--frozen-lockfile"
          ],
          [
            "yarn",
            "build"
          ]
        ],
        "candidateBinary": "bin-prettier.js"
      },
      "cases": [
        {
          "name": "cache must not skip write after list-different",
          "fixtures": [
            {
              "path": "src/example.js",
              "content": "const value={a:1,b:2}\n"
            }
          ],
          "steps": [
            {
              "args": [
                "{{fixtures}}/src/example.js",
                "--list-different",
                "--cache"
              ]
            },
            {
              "args": [
                "{{fixtures}}/src/example.js",
                "--write",
                "--cache"
              ]
            },
            {
              "readFile": "{{fixtures}}/src/example.js"
            }
          ],
          "buggyBehavior": "second command exits without rewriting the unformatted file",
          "fixedBehavior": "second command rewrites the file to Prettier output",
          "compare": "fixed_side_effect_exact"
        }
      ],
      "evidence": [
        "https://github.com/prettier/prettier/issues/13015",
        "https://prettier.io/blog/2022/11/23/2.8.0.html",
        "https://prettier.io/docs/cli"
      ]
    },
