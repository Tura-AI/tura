{
  "name": "shell_command",
  "description": "Internal command_run command for session shell commands.",
  "input_schema": {
    "type": "object",
    "required": ["command_line"],
    "properties": {
      "command_line": {
        "type": "string"
      },
      "step": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "output_schema": {
    "type": "object"
  }
}
